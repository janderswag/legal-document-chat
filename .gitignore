# OS
.DS_Store

# Secrets and local config (never commit real secrets; only .env.example is tracked)
.env
.env.*
!.env.example

# Local data — fake/sanitized corpora, indexes, logs, backups (never committed)
documents/
indexes/
backups/
logs/
config/

# Eval run outputs — raw model answers/citations from a measurement run (D-28: only
# eval/ schema/metadata/questions are tracked, never run outputs or document bodies)
eval/results/

# Model caches / large artifacts
*.gguf
*.bin
models/

# Python (for later milestones)
__pycache__/
*.pyc
.venv/
venv/

# Credentials / keys — defense-in-depth so a contributor can never commit a real
# secret (only .env.example is ever tracked). Never commit real keys.
*.pem
*.key
*.p12
*.pfx
*.keystore
id_rsa*
credentials.json
service-account*.json
*-credentials.json
secrets.*

# Vector stores / local app data (also in pipeline/.gitignore — root belt-and-suspenders)
.lancedb*/
*.lance
.kb_catalog*.db

# Node / JS tooling (none today, but guard future contributors)
node_modules/
npm-debug.log*
.pnpm-debug.log*
.gstack/
