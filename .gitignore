# OS
.DS_Store

# Secrets and local config (never commit real secrets; only .env.example is tracked)
.env
.env.*
!.env.example

# Local data — fake/sanitized corpora, indexes, logs, backups (never committed)
documents/
indexes/
backups/
logs/
config/

# Eval run outputs — raw model answers/citations from a measurement run (D-28: only
# eval/ schema/metadata/questions are tracked, never run outputs or document bodies)
eval/results/

# Model caches / large artifacts
*.gguf
*.bin
models/

# Python (for later milestones)
__pycache__/
*.pyc
.venv/
venv/
